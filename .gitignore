# OS and editors
.DS_Store
Thumbs.db

# Secrets and env
.env
.env.*
!.env.example

# Node and frontend
node_modules/
dist/
coverage/
.vite/

# Go
bin/
*.test
# Go build outputs land at the package directory by default; protect the ones
# produced by `go build ./cmd/api` / `./cmd/refstage`.
/backend/api
/tools/reference-pipeline/refstage
/tools/devtools/copyright/apply

# Rust / Tauri
target/
src-tauri/target/

# Logs
*.log

# Reference data payloads
reference-data/raw/*
!reference-data/raw/.gitignore
reference-data/staged/*
!reference-data/staged/.gitignore
reference-data/normalized/*
!reference-data/normalized/.gitignore

# Local runtime data
neo4j-data/
prometheus-data/
grafana-data/
tempo-data/

# Git worktrees
.worktrees/
