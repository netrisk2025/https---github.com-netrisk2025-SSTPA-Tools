{
  "name": "sstpa-tool",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "addons/*",
    "packages/*"
  ],
  "scripts": {
    "workspaces:build": "npm run build --workspace @sstpa/desktop-shell",
    "workspaces:lint": "npm run lint --workspaces --if-present",
    "workspaces:typecheck": "npm run typecheck --workspaces --if-present",
    "workspaces:test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.24.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vite": "^6.3.2",
    "vitest": "^3.1.1"
  }
}
