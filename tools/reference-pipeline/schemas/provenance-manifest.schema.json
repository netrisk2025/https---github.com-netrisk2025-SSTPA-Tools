{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sstpa.local/schemas/provenance-manifest.schema.json",
  "title": "ReferenceProvenanceManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "framework",
    "version",
    "stage",
    "generatedAt",
    "rawArtifacts",
    "stagedArtifacts"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "framework": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "sourceTitle": {
      "type": "string"
    },
    "sourceLastModified": {
      "type": "string"
    },
    "rawArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "stagedArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "path",
        "role",
        "sha256",
        "bytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "recordCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
